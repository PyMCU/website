---
// Keep this page static in hybrid mode
export const prerender = false;

import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Waitlist from '../components/widgets/Waitlist.astro';

import pymcuLogo from '../../public/images/pymcu-logo.png';

const metadata = {
  title: 'PyMCU — Python to MCUs. Free. Deterministic. AOT.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Public Alpha Coming Soon"
    actions={[
      {
        variant: 'primary',
        text: 'Join the Waitlist',
        href: '#waitlist',
      },
    ]}
    image={{ src: pymcuLogo, alt: 'PyMCU Logo' }}
  >
    <Fragment slot="title">
      <span class="text dark:text-accent">Py</span><span class="text-accent dark:text-white">MCU</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">PyMCU</span> is a free, deterministic compiler that brings
        <span class="font-semibold">Python</span> to microcontrollers. It compiles a statically-typed subset of Python into
        <span class="font-semibold">bare-metal machine code</span> with zero runtime overhead—no heap, no interpreter, and
        no garbage collection. Currently focusing on <span class="font-semibold">AVR (Arduino)</span>, with other
        architectures to follow.
      </span>
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Philosophy:" description="Determinism, No OS and High Performance" />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Features"
    title="What you will get with PyMCU"
    subtitle="A free, deterministic compiler designed to bring the simplicity of Python to microcontrollers. A new way to write embedded software that is predictable, efficient and accessible."
    items={[
      {
        title: 'Ahead-Of-Time Compilation',
        description:
          'PyMCU is an AOT compiler that turns a statically-typed subset of Python into efficient bare-metal machine code.',
        icon: 'tabler:terminal-2',
      },
      {
        title: 'Zero Runtime Overhead',
        description:
          'Run firmware without a heap, interpreter, or garbage collection. Enjoy the full performance of your MCU.',
        icon: 'tabler:gauge',
      },
      {
        title: 'AVR Support',
        description:
          'Current development is focused on the AVR architecture (Arduino Uno), bringing Python to the most popular 8-bit devices.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Deterministic Execution',
        description: 'Predictable timing for your embedded projects, ensuring your code runs exactly when it should.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Ready-to-use HALs',
        description: 'Hardware Abstraction Layers that make GPIO, timers, and peripherals easy to use from day one.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Open Source',
        description: 'PyMCU is community-driven and licensed under MIT, open for feedback and contributions.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    id="inside-pymcu"
    tagline="Inside PyMCU"
    title="Python Meets Bare Metal!"
    columns={2}
    items={[
      {
        title: 'AOT Compilation',
        description:
          'PyMCU transforms a statically-typed subset of Python directly into bare-metal machine code, ensuring peak performance and reliability.',
      },
      {
        title: 'No Heap, No Interpreter',
        description:
          'Unlike other Python implementations for MCUs, PyMCU has zero runtime overhead. No garbage collection and no dynamic memory.',
      },
      {
        title: 'Deterministic Timing',
        description:
          'Built for applications where timing is critical. Your firmware runs predictably without OS interruptions.',
      },
      {
        title: 'Focused on AVR',
        description:
          'Currently optimized for the ATmega328P (Arduino Uno), providing a clean path from high-level Python to 8-bit hardware.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="steps"
    title="Get your first firmware running soon with PyMCU."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Stay updated</span>',
        description:
          'Join the waitlist to be notified as soon as the PyMCU compiler is released. Once available, you can install it via pipx: <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">pipx install pymcu-compiler</code>.',
        icon: 'tabler:package',
      },
      {
        title: 'Step 2: <span class="font-medium">Prepare your code</span>',
        description:
          'Get ready to write firmware in a statically-typed subset of Python. Familiar, clean, and built to compile directly to bare-metal machine code.',
        icon: 'tabler:brand-python',
      },
      {
        title: 'Step 3: <span class="font-medium">Flash & test</span>',
        description:
          'When released, you will be able to flash generated binaries to your Arduino Uno and enjoy zero runtime overhead and deterministic timing.',
        icon: 'tabler:usb',
      },
      {
        title: 'Coming Soon!',
        icon: 'tabler:clock',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

  <!-- Roadmap Widget ******* -->

  <!-- 
  <RoadmapArchitectures
    id="roadmap"
    tagline="Roadmap"
    title="Architecture Support Timeline"
    subtitle="Our planned microcontroller support roadmap"
    columns={2}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </RoadmapArchitectures>
  -->

  <!-- HighlightedPosts Widget ******* -->

  <!--
  <BlogLatestPosts
    title="Find out more content in our Blog"
    information={`The blog is used to display AstroWind documentation.
                        Each new article will be an important step that you will need to know to be an expert in creating a website using Astro + Tailwind CSS.
                        Astro is a very interesting technology. Thanks.
                `}
  />
  -->

  <!-- FAQs Widget ******************* -->

  <FAQs
    id="faqs"
    title="Frequently Asked Questions"
    subtitle="Dive into the following questions to gain insights into what PyMCU is, where it’s going, and how it can reshape embedded development with Python."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What is PyMCU?',
        description:
          'PyMCU is an Ahead-Of-Time (AOT) compiler that translates a statically-typed subset of Python into bare-metal machine code. It is designed to be deterministic, lightweight, and efficient, bringing the simplicity of Python into the world of low-level development.',
      },
      {
        title: 'Is PyMCU production-ready?',
        description:
          'PyMCU is currently in Alpha and is being prepared for its first release. Active development is focused on the AVR architecture (Arduino Uno). We will soon be opening access for makers and developers to try it out and provide feedback.',
      },
      {
        title: 'How is PyMCU being built?',
        description:
          'PyMCU is built as an AOT compiler. It parses standard Python using AST, lowers it to a compact Intermediate Representation (IR), and then generates optimized machine code. This approach ensures zero runtime overhead—no interpreter and no heap required.',
      },
      {
        title: 'What license does PyMCU use?',
        description:
          'PyMCU is released under the MIT License — simple, permissive, and open. This ensures anyone can use, adapt, or contribute to the project with full transparency.',
      },
      {
        title: 'Will it support official toolchains?',
        description:
          'Yes, the long-term plan is to align with official toolchains provided by each vendor (such as those for PIC, AVR, ARM Cortex-M, and ESP32). This will let developers combine PyMCU with trusted ecosystems they already know.',
      },
      {
        title: 'Which architectures are supported?',
        description:
          'The primary focus of current development is AVR (ATmega328P/Arduino Uno). Support for other architectures like PIC, ARM Cortex-M, and ESP32 is planned for future releases.',
      },
      {
        title: 'How does it differ from MicroPython or CircuitPython?',
        description:
          'PyMCU is not an interpreter. It doesn’t run a VM or rely on dynamic memory. Instead, it compiles directly to machine code, with deterministic timing and no garbage collection. It is designed for developers who need Python’s clarity but require bare-metal reliability.',
      },
      {
        title: 'How can I get involved?',
        description:
          'You can help shape PyMCU by following the project on GitHub, sharing feedback, and contributing code, documentation, or testing. Every contribution helps strengthen and grow the ecosystem.',
      },
    ]}
  />
  <Waitlist id="waitlist" title="Join the Alpha" subtitle="Be the first to experience PyMCU" tagline="Early Access" />
</Layout>
