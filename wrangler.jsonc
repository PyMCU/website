{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pymcu",
  "compatibility_date": "2025-09-27",
  "main": "dist/_worker.js/index.js",
  "workers_dev": false,
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    }
  }
}
